# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@cluster.mongodb.net/
MONGO_URI=mongodb+srv://your_user:your_password@cluster.mongodb.net/

# MongoDB database name (optional, defaults to market_db)
DB_NAME=market_db

# NewsAPI key — get one free at https://newsapi.org
NEWS_API_KEY=your_newsapi_key_here
